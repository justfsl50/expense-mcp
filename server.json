{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.justfsl50/expense-mcp",
    "description": "Personal Expense Tracker MCP Server — expenses, income, budgets & savings goals",
    "repository": {
        "url": "https://github.com/justfsl50/expense-mcp",
        "source": "github"
    },
    "version": "1.0.1",
    "packages": [
        {
            "registryType": "pypi",
            "identifier": "expense-mcp",
            "version": "1.0.1",
            "transport": {
                "type": "stdio"
            },
            "environmentVariables": [
                {
                    "description": "SQLite or PostgreSQL database URL",
                    "isRequired": false,
                    "format": "string",
                    "isSecret": false,
                    "name": "DATABASE_URL"
                },
                {
                    "description": "Currency symbol (default: ₹)",
                    "isRequired": false,
                    "format": "string",
                    "isSecret": false,
                    "name": "CURRENCY"
                },
                {
                    "description": "User ID for multi-user setups",
                    "isRequired": false,
                    "format": "string",
                    "isSecret": false,
                    "name": "DEFAULT_USER"
                }
            ]
        }
    ]
}